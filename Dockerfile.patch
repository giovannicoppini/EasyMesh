# ============================================================================
# PATCH: Add EasyMesh Dependencies
# ============================================================================
# 
# Find the RUN pip install line that installs Python dependencies, and modify:
#
# BEFORE:
#   RUN pip install --no-cache-dir \
#       numpy scipy matplotlib \
#       ...other packages...
#
# AFTER:
#   RUN pip install --no-cache-dir \
#       numpy scipy matplotlib \
#       easymesh \
#       ...other packages...
#

# ============================================================================
# PATCH: Add EasyMesh Python Module
# ============================================================================
#
# Find the line that copies Python modules, and add:
#
# BEFORE:
#   COPY src/surf_shyfem /app/surf_shyfem
#
# AFTER:
#   COPY src/surf_shyfem /app/surf_shyfem
#   
#   # Add EasyMesh integration module
#   COPY easymesh_3d.py /app/surf_shyfem/preprocessing/core/meshing/easymesh_3d.py
#   COPY create_grid_3d.py /app/surf_shyfem/preprocessing/core/meshing/create_grid_3d.py
#

# ============================================================================
# EXAMPLE: Complete Modified Dockerfile Section
# ============================================================================
#
# FROM ubuntu:22.04
# 
# ENV DEBIAN_FRONTEND=noninteractive \
