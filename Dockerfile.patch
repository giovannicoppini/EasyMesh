# # Add EasyMesh integration (NEW)
# COPY easymesh_3d.py /app/surf_shyfem/preprocessing/core/meshing/easymesh_3d.py
# COPY create_grid_3d.py /app/surf_shyfem/preprocessing/core/meshing/create_grid_3d.py
# 
# # Verify installation
# RUN python3 -c "import easymesh; print('EasyMesh installed:', easymesh.__version__)"
# 
# ENTRYPOINT ["python3"]
# ============================================================================

# ============================================================================
# CONFIGURATION: Enable EasyMesh in config.json
# ============================================================================
#
# To use EasyMesh, modify your config JSON:
#
# "meshing": {
#   "use_easymesh": true,
#   "easymesh": {
#     "resolution": {
#       "sizemin": 100.0,
#       "sizemax": 5000.0
#     },
#     "optimize_bandwidth": true,
#     "refine_bathymetry": false,
#     "gradient_threshold": 0.1
#   },
#   "nested_grid": {
#     ...existing config...
#   }
# }
#

# ============================================================================
# ROLLBACK: Disable EasyMesh
# ============================================================================
#
# To disable EasyMesh and use legacy shypre:
#   "use_easymesh": false
#
# This maintains full backward compatibility with existing SURF workflows.
#

